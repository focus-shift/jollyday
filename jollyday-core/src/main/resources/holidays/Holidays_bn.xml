    <!-- Islamic (Hijri) holidays. Actual Gregorian dates are computed from the Hijri calendar
         and may differ by a day or two from the officially gazetted dates (moon sighting). -->
    <IslamicHoliday type="NEWYEAR"/>
    <IslamicHoliday type="MAWLID_AN_NABI"/>
    <IslamicHoliday type="LAILAT_AL_MIRAJ"/>
