<?xml version="1.0" encoding="UTF-8"?>

<Configuration hierarchy="lr" description="Liberia"
               xmlns="https://focus_shift.de/jollyday/schema/holiday"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="https://focus_shift.de/jollyday/schema/holiday https://focus_shift.de/jollyday/schema/holiday/holiday.xsd">
  <Holidays>
    <Fixed month="JANUARY" day="1" descriptionPropertiesKey="NEW_YEAR"/>
    <Fixed month="FEBRUARY" day="11" descriptionPropertiesKey="ARMED_FORCES_DAY"/>
    <Fixed month="MARCH" day="15" descriptionPropertiesKey="JOSEPH_JENKINS_ROBERTS_BIRTHDAY"/>
    <Fixed month="MAY" day="14" descriptionPropertiesKey="NATIONAL_UNIFICATION_DAY"/>
    <Fixed month="JULY" day="26" descriptionPropertiesKey="INDEPENDENCE_DAY"/>
