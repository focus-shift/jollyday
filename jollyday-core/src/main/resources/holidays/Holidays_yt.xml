<?xml version="1.0" encoding="UTF-8"?>

<Configuration hierarchy="yt" description="Mayotte"
               xmlns="https://focus_shift.de/jollyday/schema/holiday"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="https://focus_shift.de/jollyday/schema/holiday https://focus_shift.de/jollyday/schema/holiday/holiday.xsd">
  <Holidays>
    <!-- The eleven national French public holidays (Code du travail, Art. L3133-1) plus
         the commemoration of the abolition of slavery on 27 April (Art. L3422-2), which is
         specific to Mayotte. French law provides no weekend substitution, so holidays are
         observed on their fixed dates.

         Unlike Martinique/Guadeloupe, Mayotte was governed by its own separate "Code du
         travail applicable à Mayotte" until it was merged into the general (metropolitan)
         Code du travail's overseas title by Ordonnance n°2017-1491 of 25 October 2017,
         effective 1 January 2018. The 2004-2007 "journée de solidarité" suspension of Whit
         Monday (which applied in Martinique/Guadeloupe under the general code) therefore did
         not apply to Mayotte, which was not yet under that code at the time - so no validTo/
         validFrom gap is modelled here for WHIT_MONDAY.

         Aïd El Kébir (Eid al-Adha) is, per the DIECCTE Mayotte "Jours fériés" fact sheet,
         chômé ET payé (paid non-working day) on the same footing as 1 January and Easter
         Monday, by virtue of the extended interprofessional agreement of 21 August 1998
         (arrêté d'extension n°102/SG/DTEFP) - so it is modelled as a regular PUBLIC_HOLIDAY.

         Miradji (Lailat al Miraj), Idi El Fitri (Eid al-Fitr) and Maoulid (Mawlid an-Nabi) are
         explicitly named in Art. L3422-3 as additional days that collective agreements or
         local usage may provide for, but - unlike Aïd El Kébir - they are not backed by a
         generally-binding extended agreement; their observance depends on employer-specific
         or branch collective agreements. They are therefore modelled as OBSERVANCE, not as
         guaranteed public holidays. -->
    <Fixed month="JANUARY" day="1" descriptionPropertiesKey="NEW_YEAR"/>
    <Fixed month="APRIL" day="27" descriptionPropertiesKey="ABOLITION_OF_SLAVERY"/>
    <Fixed month="MAY" day="1" descriptionPropertiesKey="LABOUR_DAY"/>
    <Fixed month="MAY" day="8" descriptionPropertiesKey="VICTORY_DAY"/>
    <Fixed month="JULY" day="14" descriptionPropertiesKey="NATIONAL_DAY"/>
    <Fixed month="AUGUST" day="15" descriptionPropertiesKey="ASSUMPTION_MARY"/>
    <Fixed month="NOVEMBER" day="1" descriptionPropertiesKey="ALL_SAINTS"/>
    <Fixed month="NOVEMBER" day="11" descriptionPropertiesKey="ARMISTICE"/>
    <Fixed month="DECEMBER" day="25" descriptionPropertiesKey="CHRISTMAS"/>

    <ChristianHoliday type="EASTER_MONDAY"/>
    <ChristianHoliday type="ASCENSION_DAY"/>
    <ChristianHoliday type="WHIT_MONDAY"/>

    <IslamicHoliday type="ID_UL_ADHA"/>
    <IslamicHoliday type="ID_AL_FITR" localizedType="OBSERVANCE"/>
    <IslamicHoliday type="MAWLID_AN_NABI" localizedType="OBSERVANCE"/>
    <IslamicHoliday type="LAILAT_AL_MIRAJ" localizedType="OBSERVANCE"/>
  </Holidays>

  <Sources>
    <Source>https://mayotte.deets.gouv.fr/sites/mayotte.deets.gouv.fr/IMG/pdf/jours_feries1.pdf</Source>
    <Source of="Code du travail Art. L3422-2 and L3422-3">https://www.legifrance.gouv.fr/codes/section_lc/LEGITEXT000006072050/LEGISCTA000006160771/</Source>
    <Source of="Ordonnance n°2017-1491 du 25 octobre 2017">https://www.legifrance.gouv.fr/jorf/id/JORFTEXT000035762815</Source>
    <Source of="ISO 3166-2">https://en.wikipedia.org/wiki/ISO_3166-2:YT</Source>
    <Source of="ISO 3166">https://www.iso.org/obp/ui/#iso:code:3166:YT</Source>
  </Sources>
</Configuration>
