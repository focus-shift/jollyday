<?xml version="1.0" encoding="UTF-8"?>

<Configuration hierarchy="jo" description="Jordan"
               xmlns="https://focus_shift.de/jollyday/schema/holiday"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="https://focus_shift.de/jollyday/schema/holiday https://focus_shift.de/jollyday/schema/holiday/holiday.xsd">
  <Holidays>
    <!-- Fixed date national holidays -->
    <Fixed month="JANUARY" day="1" descriptionPropertiesKey="NEW_YEAR"/>
    <Fixed month="MAY" day="1" descriptionPropertiesKey="LABOUR_DAY"/>
    <Fixed month="MAY" day="25" descriptionPropertiesKey="INDEPENDENCE_DAY"/>
    <Fixed month="DECEMBER" day="25" descriptionPropertiesKey="FIRST_CHRISTMAS_DAY"/>
    <Fixed month="DECEMBER" day="26" descriptionPropertiesKey="SECOND_CHRISTMAS_DAY"/>

    <!-- Christian holidays (observed on the Orthodox/Julian chronology) -->
    <ChristianHoliday type="EASTER" chronology="JULIAN"/>
    <ChristianHoliday type="EASTER_MONDAY" chronology="JULIAN"/>

    <!-- Islamic holidays (Hijri calendar driven) -->
    <IslamicHoliday type="NEWYEAR"/>
    <IslamicHoliday type="MAWLID_AN_NABI"/>
    <IslamicHoliday type="ID_AL_FITR"/>
    <IslamicHoliday type="ID_UL_ADHA"/>

    <!-- Palm Sunday: 7 days before Easter -->
    <RelativeToEasterSunday descriptionPropertiesKey="christian.PALM_SUNDAY">
      <chronology>JULIAN</chronology>
      <days>-7</days>
    </RelativeToEasterSunday>

  </Holidays>

  <Sources>
    <Source>https://en.wikipedia.org/wiki/Public_holidays_in_Jordan</Source>
    <Source of="ISO 3166">https://www.iso.org/obp/ui/#iso:code:3166:JO</Source>
    <Source of="ISO 3166-2">https://en.wikipedia.org/wiki/ISO_3166-2:JO</Source>
  </Sources>
</Configuration>


