<?xml version="1.0" encoding="UTF-8"?>

<Configuration hierarchy="tj" description="Tajikistan"
               xmlns="https://focus_shift.de/jollyday/schema/holiday"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="https://focus_shift.de/jollyday/schema/holiday https://focus_shift.de/jollyday/schema/holiday/holiday.xsd">
  <Holidays>
    <!-- National fixed holidays -->
    <Fixed month="JANUARY" day="1" descriptionPropertiesKey="NEW_YEAR"/>
    <Fixed month="MARCH" day="8" descriptionPropertiesKey="INTERNATIONAL_WOMAN"/>
    <!-- Nowruz (March 21-24) -->
    <Fixed month="MARCH" day="21" descriptionPropertiesKey="NOWRUZ"/>
    <Fixed month="MARCH" day="22" descriptionPropertiesKey="NOWRUZ"/>
    <Fixed month="MARCH" day="23" descriptionPropertiesKey="NOWRUZ"/>
    <Fixed month="MARCH" day="24" descriptionPropertiesKey="NOWRUZ"/>
    <Fixed month="MAY" day="1" descriptionPropertiesKey="LABOUR_DAY"/>
    <Fixed month="MAY" day="9" descriptionPropertiesKey="VICTORY"/>
    <Fixed month="JUNE" day="27" descriptionPropertiesKey="NATIONAL_UNITY_DAY"/>
    <Fixed month="SEPTEMBER" day="9" descriptionPropertiesKey="INDEPENDENCE_DAY"/>
    <Fixed month="NOVEMBER" day="6" descriptionPropertiesKey="CONSTITUTION_DAY"/>

    <!-- Islamic calendar holidays -->
    <IslamicHoliday type="ID_AL_FITR"/>
    <IslamicHoliday type="ID_UL_ADHA"/>
  </Holidays>

  <Sources>
    <Source>https://en.wikipedia.org/wiki/Public_holidays_in_Tajikistan</Source>
    <Source of="ISO 3166">https://www.iso.org/obp/ui/#iso:code:3166:TJ</Source>
    <Source of="ISO 3166-2">https://en.wikipedia.org/wiki/ISO_3166-2:TJ</Source>
  </Sources>
</Configuration>

