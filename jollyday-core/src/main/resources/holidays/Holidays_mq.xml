<?xml version="1.0" encoding="UTF-8"?>

<Configuration hierarchy="mq" description="Martinique"
               xmlns="https://focus_shift.de/jollyday/schema/holiday"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="https://focus_shift.de/jollyday/schema/holiday https://focus_shift.de/jollyday/schema/holiday/holiday.xsd">
  <Holidays>
    <!-- The eleven national French public holidays (Code du travail, Art. L3133-1) plus
         the commemoration of the abolition of slavery on 22 May (Art. L3422-2), which is
         specific to Martinique (the date of the 1848 uprising that forced the governor to
         proclaim immediate abolition). French law provides no weekend substitution, so
         holidays are observed on their fixed dates.

         21 July ("Fête Victor Schoelcher") is deliberately NOT included: French Wikipedia's
         "jours fériés en France" article explicitly lists it under "fêtes non fériées"
         (non-public-holiday observances) for both Guadeloupe and Martinique, and independent
         sources confirm that in Martinique it is only marked locally by the commune of
         Schoelcher, not a territory-wide day off - unlike Guadeloupe, where a separate 27 May
         abolition holiday exists. Several aggregator sites incorrectly list 21 July as an
         official Martinique holiday; do not trust them over the statute. -->
    <Fixed month="JANUARY" day="1" descriptionPropertiesKey="NEW_YEAR"/>
    <Fixed month="MAY" day="1" descriptionPropertiesKey="LABOUR_DAY"/>
    <Fixed month="MAY" day="8" descriptionPropertiesKey="VICTORY_DAY"/>
    <Fixed month="MAY" day="22" descriptionPropertiesKey="ABOLITION_OF_SLAVERY"/>
    <Fixed month="JULY" day="14" descriptionPropertiesKey="NATIONAL_DAY"/>
    <Fixed month="AUGUST" day="15" descriptionPropertiesKey="ASSUMPTION_MARY"/>
    <Fixed month="NOVEMBER" day="1" descriptionPropertiesKey="ALL_SAINTS"/>
    <Fixed month="NOVEMBER" day="11" descriptionPropertiesKey="ARMISTICE"/>
    <Fixed month="DECEMBER" day="25" descriptionPropertiesKey="CHRISTMAS"/>

    <ChristianHoliday type="EASTER_MONDAY"/>
    <ChristianHoliday type="ASCENSION_DAY"/>
    <!-- Whit Monday was not a day off from 2004 to 2007 (Journée de solidarité). -->
    <ChristianHoliday type="WHIT_MONDAY" validTo="2003"/>
    <ChristianHoliday type="WHIT_MONDAY" validFrom="2008"/>
  </Holidays>

  <Sources>
    <Source>https://en.wikipedia.org/wiki/Public_holidays_in_Martinique</Source>
    <Source of="Code du travail Art. L3422-2">https://www.legifrance.gouv.fr/codes/article_lc/LEGIARTI000035902463</Source>
    <Source of="fr.wikipedia.org - Jours fériés en France (21 juillet listed as non-férié)">https://fr.wikipedia.org/wiki/Jours_f%C3%A9ri%C3%A9s_en_France</Source>
    <Source of="ISO 3166-2">https://en.wikipedia.org/wiki/ISO_3166-2:MQ</Source>
    <Source of="ISO 3166">https://www.iso.org/obp/ui/#iso:code:3166:MQ</Source>
  </Sources>
</Configuration>
