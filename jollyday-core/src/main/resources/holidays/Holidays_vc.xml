<?xml version="1.0" encoding="UTF-8"?>

<Configuration hierarchy="vc" description="Saint Vincent and the Grenadines"
               xmlns="https://focus_shift.de/jollyday/schema/holiday"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="https://focus_shift.de/jollyday/schema/holiday https://focus_shift.de/jollyday/schema/holiday/holiday.xsd">
  <Holidays>
    <Fixed month="JANUARY" day="1" descriptionPropertiesKey="NEW_YEAR"/>
    <Fixed month="MARCH" day="14" descriptionPropertiesKey="NATIONAL_HEROES_DAY"/>
    <Fixed month="MAY" day="1" descriptionPropertiesKey="LABOUR_DAY"/>
    <Fixed month="AUGUST" day="1" descriptionPropertiesKey="EMANCIPATION_DAY"/>
    <Fixed month="OCTOBER" day="27" descriptionPropertiesKey="INDEPENDENCE_DAY"/>
    <Fixed month="DECEMBER" day="25" descriptionPropertiesKey="CHRISTMAS"/>
    <Fixed month="DECEMBER" day="26" descriptionPropertiesKey="BOXING_DAY"/>

    <FixedWeekday which="FIRST" weekday="MONDAY" month="JULY" descriptionPropertiesKey="CARNIVAL_MONDAY"/>
    <FixedWeekday which="FIRST" weekday="TUESDAY" month="JULY" descriptionPropertiesKey="CARNIVAL_TUESDAY"/>

    <ChristianHoliday type="GOOD_FRIDAY"/>
    <ChristianHoliday type="EASTER_MONDAY"/>
    <ChristianHoliday type="WHIT_MONDAY"/>
  </Holidays>

  <Sources>
    <Source>https://en.wikipedia.org/wiki/Public_holidays_in_Saint_Vincent_and_the_Grenadines</Source>
    <Source of="ISO 3166-2">https://en.wikipedia.org/wiki/ISO_3166-2:VC</Source>
    <Source of="ISO 3166">https://www.iso.org/obp/ui/#iso:code:3166:VC</Source>
  </Sources>
</Configuration>
